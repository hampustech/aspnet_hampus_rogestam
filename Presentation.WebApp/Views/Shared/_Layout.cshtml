@{
    var title = ViewData["Title"]?.ToString();
    var pageTitle = !string.IsNullOrWhiteSpace(title)
        ? $"{title} | CoreFitness"
        : "CoreFitness | Gym & Fitness Center";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/homepage.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/memberships.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer-service.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/my-account.css" asp-append-version="true" />
</head>
<body>

    <div class="app-layout">
        <partial name="Partials/Globals/_HeaderSection" />

        @if (IsSectionDefined("Hero"))
        {
            @await RenderSectionAsync("Hero", required: false)
        }
    </div>

    <main>
        @RenderBody()
    </main>

    <footer>
        <partial name="Partials/Globals/_FooterSection" />
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>