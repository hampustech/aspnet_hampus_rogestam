@model Presentation.WebApp.Models.SignInViewModel

<section class="sign-in-card">

    <div class="sign-in-card__header">
        <h2 class="sign-in-card__title">Welcome Back!</h2>
        <p class="sign-in-card__description">
            Log in to continue your fitness journey with full access to your customized program,
            training history, and progress tracking.
        </p>
    </div>

    <div class="sign-in-card__divider"></div>

    <div class="sign-in-card__socials">
        <a href="#" class="social-btn"><i class="fa-brands fa-google"></i></a>
        <a href="#" class="social-btn"><i class="fa-brands fa-facebook-f"></i></a>
        <a href="#" class="social-btn"><i class="fa-brands fa-github"></i></a>
    </div>

    <div class="sign-in-card__or">
        <span>OR CONTINUE WITH</span>
    </div>

    <form asp-controller="Authentication" asp-action="SignIn" method="post" class="sign-in-form">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Email">Email Address *</label>
            <input asp-for="Email" type="email" placeholder="Enter Email Address" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <div class="form-group__label-row">
                <label asp-for="Password">Password</label>
                <a href="#" class="form-link">Forgot your password?</a>
            </div>
            <input asp-for="Password" type="password" placeholder="Enter Password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-checkbox">
            <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
            <label for="rememberMe">Remember me</label>
        </div>

        <button type="submit" class="btn btn-primary sign-in-form__button">
            Continue
            <i class="fa-solid fa-arrow-right"></i>
        </button>
    </form>

</section>