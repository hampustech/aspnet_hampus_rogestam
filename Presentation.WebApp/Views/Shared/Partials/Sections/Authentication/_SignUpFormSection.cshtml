@model Presentation.WebApp.Models.SignUpViewModel

<section class="sign-in-card">

    <div class="sign-in-card__header">
        <h2 class="sign-in-card__title">Become a Member</h2>
        <p class="sign-in-card__description">
            Sign up to continue your fitness journey with full access to your customized program,
            training history, and progress tracking. Stay consistent, monitor your development,
            and keep moving forward with the structure and support built into your account.
        </p>
    </div>

    <div class="sign-in-card__divider"></div>

    <div class="sign-in-card__socials">
        <a href="#" class="social-btn"><i class="fa-brands fa-google"></i></a>
        <a href="#" class="social-btn"><i class="fa-brands fa-facebook-f"></i></a>
        <a href="#" class="social-btn"><i class="fa-brands fa-github"></i></a>
    </div>

    <div class="sign-in-card__or">
        <span>OR CONTINUE WITH</span>
    </div>

    <form asp-controller="Authentication" asp-action="SignUp" method="post" class="sign-in-form">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Email">Email Address *</label>
            <input asp-for="Email" type="email" placeholder="Enter Email Address" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary sign-in-form__button">
            Continue
            <i class="fa-solid fa-arrow-right"></i>
        </button>

        <p class="sign-up-hint">We will send a verification code to your email address.</p>
    </form>

</section>