<section class="sign-in-card">

    <div class="sign-in-card__header">
        <h2 class="sign-in-card__title">Set Your Password</h2>
        <p class="sign-in-card__description">
            Set a strong password to protect your account. For security reasons, your password must be
            at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.
        </p>
    </div>

    <div class="sign-in-card__divider"></div>

    <!-- Form -->
    <form class="sign-in-form">

        <!-- Email -->
        <div class="form-group">
            <label>Email Address</label>
            <input type="email" placeholder="username@domain.com" readonly />
        </div>

        <!-- Password -->
        <div class="form-group">
            <label>Password</label>
            <input type="password" placeholder="Enter Password" />
        </div>

        <!-- Button -->
        <button type="submit" class="btn btn-primary sign-in-form__button">
            Continue
            <i class="fa-solid fa-arrow-right"></i>
        </button>

        <!-- Terms -->
        <div class="form-checkbox">
            <input type="checkbox" id="terms" />
            <label for="terms">Accept user terms and conditions</label>
        </div>

    </form>

</section>
